# =============================================================================
# Backend (Flask) — plantilla de variables de entorno
# =============================================================================
# Renombra a `.env` (con el punto) y completa los valores.
# =============================================================================

# JWT signing key. OBLIGATORIA — el backend NO arranca sin esto.
# Mínimo 32 chars. Genérala con:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=

# Origins permitidos por CORS. CSV. Sin esto, el backend rechaza requests
# del frontend. Local dev: http://localhost:5173.
# En prod (Vercel): https://tu-app.vercel.app  (sin trailing slash).
# Si tienes dominio custom: https://tu-app.vercel.app,https://tudominio.com
ALLOWED_ORIGINS=http://localhost:5173

# Debug mode. Dejar False en prod SIEMPRE — debug=True filtra stacktraces,
# paths del filesystem y secrets si algo falla.
FLASK_DEBUG=False

# -----------------------------------------------------------------------------
# Base de datos MySQL
# -----------------------------------------------------------------------------
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=torneos_db
MYSQL_USER=torneos_user
MYSQL_PASSWORD=

# Solo necesaria si arrancas el contenedor MySQL local (docker-compose).
# En Railway, el plugin MySQL no expone root password.
MYSQL_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# Seed (solo para correr backend/seed.py — datos de prueba)
# -----------------------------------------------------------------------------

# Password del admin. OBLIGATORIA al correr seed.py. Mínimo 8 chars.
ADMIN_PASSWORD=

# Override del nickname del admin (default: 'admin').
# ADMIN_NICKNAME=admin

# =1 para resetear password/role de un admin existente.
# ADMIN_FORCE_RESET=

# Password compartida para los usuarios de prueba (tm_carlos, coach_*, player_*)
# Default: 'password123' (mínimo 8 chars).
# SEED_USER_PASSWORD=password123
